// ekkieinn.is — Prisma schema
// SQLite by default (see DATABASE_URL). For PostgreSQL, change provider to
// "postgresql" and update DATABASE_URL, then run `npx prisma db push`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  MODERATOR
  ADMIN
}

enum ApprovalStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum SupportType {
  LEGAL
  PSYCH
}

enum SupportStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

// Heuristic + AI assessment of whether a registrant is likely male. EkkiEinn.is
// is a men's support community, so this assists admin approval decisions.
enum GenderAssessment {
  LIKELY_MALE
  LIKELY_FEMALE
  UNCERTAIN
}

// ---- Users -----------------------------------------------------------------

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  username     String?  @unique
  // Full legal name collected at registration (required for new sign-ups).
  name         String   @default("")
  displayName  String?
  image        String?
  isAnonymous  Boolean  @default(true)
  role         Role     @default(USER)

  // Admin must approve new (non-admin) users before they can sign in.
  approvalStatus ApprovalStatus @default(PENDING_APPROVAL)

  // Gender assessment (heuristic + optional AI) used to assist approval.
  genderAssessment        GenderAssessment @default(UNCERTAIN)
  genderAssessmentScore   Float?
  genderAssessmentDetails String?

  // Email verification (custom flow — single-use token, 48h expiry).
  emailVerified  Boolean   @default(false)
  verifyToken    String?   @unique
  verifyTokenExp DateTime?

  // Last successful sign-in (stamped in the NextAuth authorize callback).
  lastLoginAt DateTime?
  // IP address captured at the last successful sign-in (best-effort).
  lastLoginIp String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  threads         Thread[]
  replies         Reply[]
  supportRequests SupportRequest[]
}

// ---- Forum -----------------------------------------------------------------

model Category {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  icon        String
  order       Int      @default(0)
  // Some categories (e.g. "Gerendur") require an application/approval.
  restricted  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  threads     Thread[]
}

model Thread {
  id         String @id @default(cuid())
  categoryId String
  authorId   String

  title   String
  // Publicly stored content — names are anonymized BEFORE saving.
  content String

  // PRIVATE — never shown publicly. Visible to admins only, used to connect
  // multiple cases about the same perpetrator for legal support.
  victimName      String?
  perpetratorName String?

  isAnonymous        Boolean @default(true)
  isPinned           Boolean @default(false)
  isLocked           Boolean @default(false)
  isHidden           Boolean @default(false)
  hasAnonymizedNames Boolean @default(false)
  // AI name-moderation (manual mode): flagged for admin review + suggestions.
  needsReview        Boolean @default(false)
  aiSuggestions      String?
  upvotes            Int     @default(0)

  // Content moderation: pending | approved | rejected.
  // Threads are NOT public until approved (by AI auto-approval or an admin).
  status           String  @default("pending")
  flaggedNames     String? // JSON array of detected name surface-forms
  moderationNote   String? // admin note about why it was flagged / rejected
  moderationReason String? // AI reason the thread was held (shown to author)
  suggestedText    String? // content with names replaced by [AAA]/[BBB]
  nameMap          String? // JSON: { "AAA": "Jóhanna", ... }
  aiAnalysis       String? // JSON summary of the AI/heuristic content check

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  author   User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  replies  Reply[]

  @@index([categoryId])
  @@index([perpetratorName])
}

model Reply {
  id       String @id @default(cuid())
  threadId String
  authorId String
  content  String

  // Set when the AI name check suspects a person name slipped through.
  flagged    Boolean @default(false)
  flagReason String?
  // AI name-moderation (manual mode): flagged for admin review + suggestions.
  needsReview   Boolean @default(false)
  aiSuggestions String?
  upvotes    Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  thread Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([threadId])
}

// ---- Donations -------------------------------------------------------------

model Donation {
  id              String   @id @default(cuid())
  amount          Int // smallest currency unit
  currency        String   @default("isk")
  stripePaymentId String?  @unique
  isRecurring     Boolean  @default(false)
  isAnonymous     Boolean  @default(true)
  donorName       String?
  message         String?
  createdAt       DateTime @default(now())
}

// ---- Support requests ------------------------------------------------------

model SupportRequest {
  id          String        @id @default(cuid())
  userId      String?
  name        String?
  email       String?
  type        SupportType
  description String
  status      SupportStatus @default(OPEN)
  createdAt   DateTime      @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

// ---- Admin notifications ---------------------------------------------------

model Notification {
  id        String   @id @default(cuid())
  type      String // e.g. "FLAGGED_REPLY"
  message   String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ---- Key/value settings (editable in admin) --------------------------------

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ---- Perpetrator name registry (standalone lookup) -------------------------
// A simple admin-maintained list. The public /nafnaleit page answers Já/Nei
// for a queried name; the list itself is never exposed publicly.
model PerpetratorRegistry {
  id      Int      @id @default(autoincrement())
  name    String   @unique
  addedBy String?
  addedAt DateTime @default(now())
}

// ---- Editable static pages (managed in /admin/pages) -----------------------

model Page {
  id              Int      @id @default(autoincrement())
  slug            String   @unique // t.d. "forsida", "um-okkur", "studningur"
  title           String // Titill síðu (birtist í vafraflipa)
  menuTitle       String // Heiti í valmynd
  category        String   @default("") // flokkur: "about" | "legal" | "contact" | ""
  metaDescription String   @default("")
  content         String   @default("") // HTML content
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())
}
