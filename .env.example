# ---- Database --------------------------------------------------------------
# SQLite (default). Use an absolute path in production.
DATABASE_URL="file:./dev.db"
# Production example:
# DATABASE_URL="file:/home/deploy/karlmenn/prod.db"

# ---- Auth (NextAuth.js v5) -------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-in-production"
NEXTAUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="https://ekkieinn.is"

# ---- Email -----------------------------------------------------------------
# Used for verification emails and admin notifications.
# Option A: local sendmail/postfix on the server (no third-party service):
SMTP_USE_SENDMAIL="true"
# SENDMAIL_PATH="/usr/sbin/sendmail"
MAIL_FROM="info@ekkieinn.is"
MAIL_FROM_NAME="EkkiEinn.is"
# Option B: SMTP server (used when SMTP_USE_SENDMAIL is not "true"):
SMTP_HOST="localhost"
SMTP_PORT="25"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Ekki einn <info@ekkieinn.is>"

# ---- Public site URL -------------------------------------------------------
NEXT_PUBLIC_APP_URL="https://ekkieinn.is"
PORT="3002"

# ---- AI moderation & name anonymization (optional) -------------------------
# The OpenAI key is PRIMARILY managed in the admin UI and stored in the DB
# `Setting` table (key: openai_api_key) — that value takes precedence over the
# env var below. AI content moderation (threats, harassment, hate speech,
# defamation, ...) uses OpenAI gpt-4o-mini; ANTHROPIC_API_KEY (claude-3-5-haiku)
# is used as a fallback. If neither is available, a built-in heuristic is used.
# Behaviour is controlled by the `ai_moderation_mode` Setting: off | manual | auto.
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

# ---- Stripe (optional, donations) ------------------------------------------
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
