# ---- Database --------------------------------------------------------------
# SQLite (default). Use an absolute path in production.
DATABASE_URL="file:./dev.db"
# Production example:
# DATABASE_URL="file:/home/deploy/karlmenn/prod.db"

# ---- Auth (NextAuth.js v5) -------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-in-production"
NEXTAUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="https://ekkieinn.is"

# ---- Email (SMTP) ----------------------------------------------------------
# Used for verification emails and admin notifications.
SMTP_HOST="localhost"
SMTP_PORT="25"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Ekki einn <info@ekkieinn.is>"

# ---- Public site URL -------------------------------------------------------
NEXT_PUBLIC_APP_URL="https://ekkieinn.is"
PORT="3002"

# ---- AI name anonymization (optional) --------------------------------------
# If neither key is set, a built-in heuristic anonymizer is used.
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

# ---- Stripe (optional, donations) ------------------------------------------
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
